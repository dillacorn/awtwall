#!/usr/bin/env bash
# awtwall-update - updater for awtwall
# Updates awtwall from the official GitHub repository
# Repository: https://github.com/dillacorn/awtwall

set -euo pipefail

REPO_URL="https://github.com/dillacorn/awtwall"
REPO_DIR="$HOME/.cache/awtwall-update"
PREFIX=${PREFIX:-"$HOME/.local"}
BINDIR="$PREFIX/bin"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

print_info() {
    echo -e "${BLUE}[INFO]${NC} $*"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $*"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $*"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $*"
}

# Check if git is installed
if ! command -v git &>/dev/null; then
    print_error "git is required but not installed."
    echo "Please install git and try again."
    exit 1
fi

# Get current version (if awtwall exists)
CURRENT_AWTWALL="$BINDIR/awtwall"
if [[ -f "$CURRENT_AWTWALL" ]]; then
    print_info "Found awtwall at: $CURRENT_AWTWALL"
else
    print_warning "awtwall not found at: $CURRENT_AWTWALL"
    print_info "This will perform a fresh installation."
fi

# Clone or update the repository
if [[ -d "$REPO_DIR" ]]; then
    print_info "Updating existing repository..."
    cd "$REPO_DIR"

    # Fetch latest changes
    if ! git fetch origin main 2>/dev/null; then
        print_error "Failed to fetch updates from repository."
        print_info "Removing cached repository and retrying..."
        cd "$HOME"
        rm -rf "$REPO_DIR"
        if ! git clone "$REPO_URL" "$REPO_DIR"; then
            print_error "Failed to clone repository. Check your internet connection."
            exit 1
        fi
        cd "$REPO_DIR"
    else
        # Reset to latest main only if fetch succeeded
        git reset --hard origin/main
        git clean -fd
    fi
else
    print_info "Downloading awtwall from GitHub..."
    mkdir -p "$(dirname "$REPO_DIR")"
    if ! git clone "$REPO_URL" "$REPO_DIR"; then
        print_error "Failed to clone repository. Check your internet connection."
        exit 1
    fi
    cd "$REPO_DIR"
fi

# Get the latest commit hash
LATEST_COMMIT=$(git rev-parse --short HEAD)
print_info "Latest version: $LATEST_COMMIT"

# Check if we're already up to date
if [[ -f "$CURRENT_AWTWALL" ]]; then
    # Try to find current version from awtwall file
    # (This assumes the commit hash might be embedded in the future,
    #  for now we'll just proceed with the update)
    print_info "Checking for updates..."
fi

# Show recent commits
echo
print_info "Recent changes:"
git log -5 --oneline --decorate --color=always
echo

# Confirm update
read -rp "Proceed with update/installation? [Y/n]: " confirm
case "$confirm" in
    [nN]*)
        print_warning "Update cancelled."
        exit 0
        ;;
esac

# Create backup if awtwall exists
if [[ -f "$CURRENT_AWTWALL" ]]; then
    BACKUP="$CURRENT_AWTWALL.backup.$(date +%Y%m%d-%H%M%S)"
    print_info "Creating backup: $BACKUP"
    cp "$CURRENT_AWTWALL" "$BACKUP"
fi

# Install awtwall and awtwall-update
mkdir -p "$BINDIR"

if [[ -f "$REPO_DIR/awtwall" ]]; then
    cp "$REPO_DIR/awtwall" "$BINDIR/awtwall"
    chmod +x "$BINDIR/awtwall"
    print_success "Updated awtwall"
else
    print_error "awtwall script not found in repository!"
    exit 1
fi

# Install the updater itself
UPDATER_INSTALLED=false
if [[ -f "$REPO_DIR/awtwall-update" ]]; then
    cp "$REPO_DIR/awtwall-update" "$BINDIR/awtwall-update"
    chmod +x "$BINDIR/awtwall-update"
    print_success "Updated awtwall-update"
    UPDATER_INSTALLED=true
fi

# Check PATH
case ":$PATH:" in
    *":$BINDIR:"*) ;;
    *)
        echo
        print_warning "$BINDIR is not in your PATH."
        echo "Add this to your shell config (example for bash):"
        echo "  export PATH=\"$BINDIR:\$PATH\""
        ;;
esac

echo
print_success "Update complete! (commit: $LATEST_COMMIT)"
echo
echo "Installed files:"
echo "  - awtwall -> $BINDIR/awtwall"
if [[ "$UPDATER_INSTALLED" == "true" ]]; then
    echo "  - awtwall-update -> $BINDIR/awtwall-update"
fi
echo

if [[ -n "${BACKUP:-}" ]]; then
    echo "Previous version backed up to: $BACKUP"
    echo
fi

print_info "You can now run: awtwall"